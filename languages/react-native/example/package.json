{
  "name": "@rusaint/react-native-example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "build:android": "react-native build-android --extra-params \"--no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a\"",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "build:ios": "react-native build-ios --scheme ReactNativeExample --mode Debug --extra-params \"-sdk iphonesimulator CC=clang CPLUSPLUS=clang++ LD=clang LDPLUSPLUS=clang++ GCC_OPTIMIZATION_LEVEL=0 GCC_PRECOMPILE_PREFIX_HEADER=YES ASSETCATALOG_COMPILER_OPTIMIZATION=time DEBUG_INFORMATION_FORMAT=dwarf COMPILER_INDEX_STORE_ENABLE=NO\""
  },
  "dependencies": {
    "react": "19.2.3",
    "react-native": "^0.84.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/runtime": "^7.28.4",
    "@react-native-community/cli": "^20.1.0",
    "@react-native-community/cli-platform-android": "^20.1.0",
    "@react-native-community/cli-platform-ios": "^20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/metro-config": "^0.84.0",
    "@react-native/typescript-config": "0.84.1",
    "react-native-builder-bob": "^0.40.13"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "rnx-kit": {
    "kitType": "app",
    "alignDeps": {
      "requirements": {
        "development": [
          "react-native@0.84"
        ],
        "production": [
          "react-native@0.84"
        ]
      },
      "capabilities": [
        "core-android",
        "core-ios",
        "react"
      ]
    }
  }
}
